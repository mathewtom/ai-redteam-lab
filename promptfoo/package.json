{
  "name": "ai-redteam-lab-promptfoo",
  "version": "0.2.0",
  "description": "Promptfoo configs for red-teaming SecureRAG-Sentinel and SecureRAG-Agent from the E003 perspective. See README.md.",
  "private": true,
  "scripts": {
    "sentinel:smoke": "promptfoo eval -c SecureRAG-Sentinel/configs/eval/promptfooconfig.smoke.yaml --no-cache",
    "sentinel:eval": "promptfoo eval -c SecureRAG-Sentinel/configs/eval/promptfooconfig.yaml",
    "sentinel:redteam:generate:baseline": "CI=true promptfoo redteam generate -c SecureRAG-Sentinel/configs/redteam/promptfooconfig.baseline.yaml -o SecureRAG-Sentinel/configs/redteam/baseline_attacks.yaml",
    "sentinel:redteam:generate:pipeline": "CI=true promptfoo redteam generate -c SecureRAG-Sentinel/configs/redteam/promptfooconfig.pipeline.yaml -o SecureRAG-Sentinel/configs/redteam/pipeline_attacks.yaml",
    "sentinel:redteam:baseline": "CI=true promptfoo redteam run -c SecureRAG-Sentinel/configs/redteam/promptfooconfig.baseline.yaml",
    "sentinel:redteam:pipeline": "CI=true promptfoo redteam run -c SecureRAG-Sentinel/configs/redteam/promptfooconfig.pipeline.yaml",
    "agent:redteam:generate": "CI=true promptfoo redteam generate -c SecureRAG-Agent/configs/redteam/promptfooconfig.yaml -o SecureRAG-Agent/configs/redteam/agent_attacks.yaml",
    "agent:redteam": "CI=true promptfoo redteam run -c SecureRAG-Agent/configs/redteam/promptfooconfig.yaml"
  },
  "license": "MIT",
  "dependencies": {
    "promptfoo": "^0.121.3"
  }
}
