# Copy this file to .env and fill in your key.
# .env is gitignored — never commit secrets.

# Anthropic API key — used for the attacker LLM (Claude Haiku 4.5)
# and grader LLM (Claude Haiku 4.5) in both eval and redteam configs.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pin the SecureRAG-Sentinel API base URL.
# Defaults to http://localhost:8000 if unset.
SECURERAG_API_URL=http://localhost:8000
