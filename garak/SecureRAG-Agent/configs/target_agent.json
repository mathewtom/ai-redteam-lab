{
  "rest": {
    "RestGenerator": {
      "name": "SecureRAG-Agent (E003 runtime-bound)",
      "uri": "http://localhost:8000/agent/query",
      "method": "post",
      "headers": {
        "Content-Type": "application/json"
      },
      "req_template_json_object": {
        "query": "$INPUT"
      },
      "response_json": true,
      "response_json_field": "answer",
      "skip_codes": [400, 403, 422, 429, 500],
      "request_timeout": 180
    }
  }
}
